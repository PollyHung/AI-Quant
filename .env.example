# Required credentials
ROOSTOO_API_KEY=replace_with_your_key
ROOSTOO_API_SECRET=replace_with_your_secret

# API and trading configuration
ROOSTOO_BASE_URL=https://mock-api.roostoo.com
ROOSTOO_PAIR=BTC/USD
POLL_SECONDS=10
MAX_POSITION_USD=1000
MIN_CASH_RESERVE_USD=100
POSITION_SIZE_PCT=0.25
STOP_LOSS_PCT=0.02
TAKE_PROFIT_PCT=0.04
TRAILING_STOP_PCT=0.01
MIN_HOLD_SECONDS=180
STRATEGY_MODE=dip_ladder
DIP_STEP_PCT=0.006
DIP_REBOUND_PCT=0.0015
DIP_LOOKBACK=18
DIP_MAX_TRANCHES=4
SHORT_WINDOW=5
LONG_WINDOW=20
COOLDOWN_SECONDS=30
DRY_RUN=true
LOG_LEVEL=INFO

# API resilience
REQUEST_TIMEOUT=10
MAX_RETRIES=4
MAX_CALLS_PER_MINUTE=30

# Adaptive tuning
ADAPTIVE_ENABLED=true
ADAPTIVE_REEVALUATE_LOOPS=18
ADAPTIVE_MIN_SHORT_WINDOW=3
ADAPTIVE_MAX_SHORT_WINDOW=20
ADAPTIVE_MIN_LONG_WINDOW=10
ADAPTIVE_MAX_LONG_WINDOW=60
ADAPTIVE_MIN_POSITION_SIZE_PCT=0.10
ADAPTIVE_MAX_POSITION_SIZE_PCT=0.50
ADAPTIVE_DRAWDOWN_THRESHOLD=0.05
ADAPTIVE_LOSS_STREAK_THRESHOLD=3
ADAPTIVE_HISTORY_WINDOW=36
